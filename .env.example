# Copy to .env and adjust. Only VITE_* keys are available in the app.

# Recipient shown on the intro / finale screens
VITE_RECIPIENT_NAME=Sanjai

# Unlock time (local timezone). ISO without Z = device local time.
# Example: midnight on July 22, 2026
VITE_UNLOCK_AT=2026-07-22T00:00:00

# Site base path: "/" locally or on Vercel; "/sanjaibirthdaywishes/" on GitHub Pages
VITE_BASE=/
